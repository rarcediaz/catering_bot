<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro"  name="robot">

    <xacro:include filename="intertial_macros.xacro"/>

    <material name ="white">
        <color rgba="1 1 1 1" />
    </material>

        <material name ="orange">
        <color rgba="1 0.3 0.1 1" />
    </material>

        <material name ="blue">
        <color rgba="0.2 0.2 1 1" />
    </material>

        <material name ="black">
        <color rgba="0 0 0 1" />
    </material>

    <material name="red">
        <color rgba="1 0 0 1"/>
    </material>

    <material name="dark_grey">
        <color rgba="0.1 0.1 0.1 1"/>
    </material>

    <xacro:macro name="chassis_frame_member" params="name xyz size">
        <visual name="${name}_visual">
            <origin xyz="${xyz}" rpy="0 0 0"/>
            <geometry>
                <box size="${size}"/>
            </geometry>
            <material name="white"/>
        </visual>

        <collision name="${name}_collision">
            <origin xyz="${xyz}" rpy="0 0 0"/>
            <geometry>
                <box size="${size}"/>
            </geometry>
        </collision>
    </xacro:macro>

    <!-- BASE LINK -->

    <link name="base_link">

    </link>

        <!-- BASE_FOOTPRINT -->

    <joint name="base_footprint_joint" type="fixed">
        <parent link="base_link"/>
        <child link="base_footprint"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <link name="base_footprint">
    </link>

    <!-- CHASSIS LINK-->
    <joint name ="chassis_joint" type="fixed">
        <parent link="base_link"/>
        <child link= "chassis"/>
        <origin xyz="-0.1 0 0"/>
    </joint>

    <link name="chassis">
        <xacro:chassis_frame_member name="left_side_rail" xyz="0.5 0.28 0.02" size="1.0 0.04 0.04"/>
        <xacro:chassis_frame_member name="right_side_rail" xyz="0.5 -0.28 0.02" size="1.0 0.04 0.04"/>
        <xacro:chassis_frame_member name="back_rail" xyz="0.02 0 0.02" size="0.04 0.52 0.04"/>
        <xacro:chassis_frame_member name="front_rail" xyz="0.98 0 0.02" size="0.04 0.52 0.04"/>
        <xacro:chassis_frame_member name="rear_cross_rail" xyz="0.305 0 0.02" size="0.04 0.52 0.04"/>
        <xacro:chassis_frame_member name="front_cross_rail" xyz="0.67 0 0.02" size="0.04 0.52 0.04"/>
        <xacro:chassis_frame_member name="rear_left_inner_rail" xyz="0.1625 0.1 0.02" size="0.245 0.04 0.04"/>
        <xacro:chassis_frame_member name="rear_right_inner_rail" xyz="0.1625 -0.1 0.02" size="0.245 0.04 0.04"/>

        <xacro:inertial_box mass="7.31553774" x="1.0" y="0.6" z="0.04">
            <origin xyz="0.5 0 0.02" rpy="0 0 0"/>
        </xacro:inertial_box>
    </link>

    <!-- ELECTRICAL BOX LINK -->
    <joint name="electrical_box_joint" type="fixed">
        <parent link="chassis"/>
        <child link="electrical_box"/>
        <origin xyz="0.87 0 0.032" rpy="0 0 0"/>
    </joint>

    <link name="electrical_box">
        <visual>
            <geometry>
                <box size="0.18 0.26 0.06"/>
            </geometry>
            <material name="dark_grey"/>
        </visual>

        <collision>
            <geometry>
                <box size="0.18 0.26 0.06"/>
            </geometry>
        </collision>

        <xacro:inertial_box mass="1.0" x="0.18" y="0.26" z="0.06">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_box>
    </link>

    <!-- LEFT WHEEL LINK -->
    <joint name="left_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="left_wheel"/>
        <origin xyz="0.05 0.2 -0.0538" rpy="-${pi/2} 0 0"/>
        <axis xyz="0 0 1"/>
        <limit effort="5.0" velocity="13.8"/>
    </joint>

    <link name="left_wheel">
        <visual>
            <geometry>
                <cylinder length="0.0635" radius="0.0762" />
            </geometry>
            <material name="blue"/>
        </visual>

        <collision>
            <geometry>
                <sphere radius="0.0762" />
            </geometry>
        </collision>

        <xacro:inertial_cylinder mass="0.9" length="0.0635" radius="0.0762">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_cylinder>
    </link>

    <!-- RIGHT WHEEL LINK -->
    <joint name="right_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="right_wheel"/>
        <origin xyz="0.05 -0.2 -0.0538" rpy="${pi/2} 0 0"/>
        <axis xyz="0 0 -1"/>
        <limit effort="5.0" velocity="13.8"/>
    </joint>

    <link name="right_wheel">
        <visual>
            <geometry>
                <cylinder length="0.0635" radius="0.0762" />
            </geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <geometry>
                <sphere radius="0.0762" />
            </geometry>
        </collision>

        <xacro:inertial_cylinder mass="0.9" length="0.0635" radius="0.0762">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_cylinder>
    </link>

    <!-- CASTER LEFT LINK -->
    <joint name="caster_wheel_left_joint" type="fixed">
        <parent link="chassis"/>
        <child link="caster_wheel_left"/>
        <origin xyz="0.98 0.28 -0.0665" rpy="0 0 0"/>
    </joint>

    <link name="caster_wheel_left">
        <visual>
            <geometry>
                <sphere radius="0.0635" />
            </geometry>
            <material name="black" />
        </visual>
        
        <collision>
            <geometry>
                <sphere radius="0.0635" />
            </geometry>
        </collision>

        <xacro:inertial_sphere mass="0.9" radius="0.0635">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_sphere>
    </link>

    <gazebo reference="caster_wheel_left">
        <mu1 value="0.0"/>
        <mu2 value="0.0"/>
    </gazebo>


        <!-- CASTER RIGHT LINK -->
    <joint name="caster_wheel_right_joint" type="fixed">
        <parent link="chassis"/>
        <child link="caster_wheel_right"/>
        <origin xyz="0.98 -0.28 -0.0665" rpy="0 0 0"/>
    </joint>

    <link name="caster_wheel_right">
        <visual>
            <geometry>
                <sphere radius="0.0635" />
            </geometry>
            <material name="black" />
        </visual>
        
        <collision>
            <geometry>
                <sphere radius="0.0635" />
            </geometry>
        </collision>

                <xacro:inertial_sphere mass="0.9" radius="0.0635">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_sphere>
    </link>

    <gazebo reference="caster_wheel_right">
        <mu1 value="0.0"/>
        <mu2 value="0.0"/>
    </gazebo>

    <!-- SUPPORT POST BACK LEFT LINK -->
    <joint name="support_back_left_joint" type="fixed">
        <parent link="chassis"/>
        <child link="support_back_left_block"/>
        <origin xyz="0.02 0.28 0.09" rpy="0 0 0"/>
    </joint>

    <link name="support_back_left_block">
        <visual>
            <geometry>
                <box size="0.04 0.04 0.1" />
            </geometry>
            <material name="white" />
        </visual>
        
        <collision>
            <geometry>
                <box size="0.04 0.04 0.1" />
            </geometry>
        </collision>

        <xacro:inertial_box mass="0.25" x="0.04" y="0.04" z="0.1">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_box>
    </link>


    <!-- SUPPORT POST BACK RIGHT LINK -->
    <joint name="support_back_right_joint" type="fixed">
        <parent link="chassis"/>
        <child link="support_back_right_block"/>
        <origin xyz="0.02 -0.28 0.09" rpy="0 0 0"/>
    </joint>

    <link name="support_back_right_block">
        <visual>
            <geometry>
                <box size="0.04 0.04 0.1" />
            </geometry>
            <material name="white" />
        </visual>
        
        <collision>
            <geometry>
                <box size="0.04 0.04 0.1" />
            </geometry>
        </collision>

        <xacro:inertial_box mass="0.25" x="0.04" y="0.04" z="0.1">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_box>
    </link>

    <!-- SUPPORT POST FRONT LEFT LINK -->
    <joint name="support_front_left_joint" type="fixed">
        <parent link="chassis"/>
        <child link="support_front_left_block"/>
        <origin xyz="0.98 0.28 0.09" rpy="0 0 0"/>
    </joint>

    <link name="support_front_left_block">
        <visual>
            <geometry>
                <box size="0.04 0.04 0.1" />
            </geometry>
            <material name="white" />
        </visual>
        
        <collision>
            <geometry>
                <box size="0.04 0.04 0.1" />
            </geometry>
        </collision>

        <xacro:inertial_box mass="0.25" x="0.04" y="0.04" z="0.1">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_box>
    </link>

    <!-- SUPPORT POST FRONT RIGHT LINK -->
    <joint name="support_front_right_joint" type="fixed">
        <parent link="chassis"/>
        <child link="support_front_right_block"/>
        <origin xyz="0.98 -0.28 0.09" rpy="0 0 0"/>
    </joint>

    <link name="support_front_right_block">
        <visual>
            <geometry>
                <box size="0.04 0.04 0.1" />
            </geometry>
            <material name="white" />
        </visual>
        
        <collision>
            <geometry>
                <box size="0.04 0.04 0.1" />
            </geometry>
        </collision>

        <xacro:inertial_box mass="0.25" x="0.04" y="0.04" z="0.1">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_box>
    </link>

    <!-- PLASTIC TOP BOARD LINK -->
    <joint name="table_top_joint" type="fixed">
        <parent link="chassis"/>
        <child link="table_top_block"/>
        <origin xyz="0.5 0 0.1475" rpy="0 0 0"/>
    </joint>

    <link name="table_top_block">
        <visual>
            <geometry>
                <box size="1.0 0.6 0.015"/>
            </geometry>
            <material name="white"/>
        </visual>
        
        <collision>
            <geometry>
                <box size="1.0 0.6 0.015" />
            </geometry>
        </collision>

        <xacro:inertial_box mass="1.0" x="1.0" y="0.6" z="0.015">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_box>
    </link>


</robot>

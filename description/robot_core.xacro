<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro"  name="robot">

    <xacro:include filename="intertial_macros.xacro"/>

    <material name ="white">
        <color rgba="1 1 1 1" />
    </material>

        <material name ="orange">
        <color rgba="1 0.3 0.1 1" />
    </material>

        <material name ="blue">
        <color rgba="0.2 0.2 1 1" />
    </material>

        <material name ="black">
        <color rgba="0 0 0 1" />
    </material>

    <material name="red">
        <color rgba="1 0 0 1"/>
    </material>

    <!-- BASE LINK -->

    <link name="base_link">

    </link>

        <!-- BASE_FOOTPRINT -->

    <joint name="base_footprint_joint" type="fixed">
        <parent link="base_link"/>
        <child link="base_footprint"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <link name="base_footprint">
    </link>

    <!-- CHASSIS LINK-->
    <joint name ="chassis_joint" type="fixed">
        <parent link="base_link"/>
        <child link= "chassis"/>
        <origin xyz="-0.1 0 0"/>
    </joint>

    <link name="chassis">
        <visual>
            <origin xyz="0.5334 0 0.009525" rpy="0 0 0"/>
            <geometry>
                <box size="1.0668 0.6096 0.01905"/>
            </geometry>
            <material name="white"/>
        </visual>

        <collision>
            <origin xyz="0.5334 0 0.009525" rpy="0 0 0"/>
            <geometry>
                <box size="1.0668 0.6096 0.01905"/>
            </geometry>
        </collision>

        <xacro:inertial_box mass="7.31553774" x="1.0668" y="0.6096" z="0.1905">
            <origin xyz="0.5334 0 0.009525" rpy="0 0 0"/>
        </xacro:inertial_box>
    </link>

    <!-- LEFT WHEEL LINK -->
    <joint name="left_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="left_wheel"/>
        <origin xyz="0.1524 0.2032 -0.0508" rpy="-${pi/2} 0 0"/>
        <axis xyz="0 0 1"/>
        <limit effort="5.0" velocity="13.8"/>
    </joint>

    <link name="left_wheel">
        <visual>
            <geometry>
                <cylinder length="0.0635" radius="0.0762" />
            </geometry>
            <material name="blue"/>
        </visual>

        <collision>
            <geometry>
                <sphere radius="0.0762" />
            </geometry>
        </collision>

        <xacro:inertial_cylinder mass="0.9" length="0.0635" radius="0.0762">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_cylinder>
    </link>

    <!-- RIGHT WHEEL LINK -->
    <joint name="right_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="right_wheel"/>
        <origin xyz="0.1524 -0.2032 -0.0508" rpy="${pi/2} 0 0"/>
        <axis xyz="0 0 -1"/>
        <limit effort="5.0" velocity="13.8"/>
    </joint>

    <link name="right_wheel">
        <visual>
            <geometry>
                <cylinder length="0.0635" radius="0.0762" />
            </geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <geometry>
                <sphere radius="0.0762" />
            </geometry>
        </collision>

        <xacro:inertial_cylinder mass="0.9" length="0.0635" radius="0.0762">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_cylinder>
    </link>

    <!-- CASTER LEFT LINK -->
    <joint name="caster_wheel_left_joint" type="fixed">
        <parent link="chassis"/>
        <child link="caster_wheel_left"/>
        <origin xyz="0.9144 0.2413 -0.0635" rpy="0 0 0"/>
    </joint>

    <link name="caster_wheel_left">
        <visual>
            <geometry>
                <sphere radius="0.0635" />
            </geometry>
            <material name="black" />
        </visual>
        
        <collision>
            <geometry>
                <sphere radius="0.0635" />
            </geometry>
        </collision>

        <xacro:inertial_sphere mass="0.9" radius="0.0635">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_sphere>
    </link>

    <gazebo reference="caster_wheel_left">
        <mu1 value="0.0"/>
        <mu2 value="0.0"/>
    </gazebo>


        <!-- CASTER RIGHT LINK -->
    <joint name="caster_wheel_right_joint" type="fixed">
        <parent link="chassis"/>
        <child link="caster_wheel_right"/>
        <origin xyz="0.9144 -0.2413 -0.0635" rpy="0 0 0"/>
    </joint>

    <link name="caster_wheel_right">
        <visual>
            <geometry>
                <sphere radius="0.0635" />
            </geometry>
            <material name="black" />
        </visual>
        
        <collision>
            <geometry>
                <sphere radius="0.0635" />
            </geometry>
        </collision>

                <xacro:inertial_sphere mass="0.9" radius="0.0635">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_sphere>
    </link>

    <gazebo reference="caster_wheel_right">
        <mu1 value="0.0"/>
        <mu2 value="0.0"/>
    </gazebo>

        <!-- SUPPORT BLOCK BACK LEFT LINK -->
    <joint name="support_back_left_joint" type="fixed">
        <parent link="chassis"/>
        <child link="support_back_left_block"/>
        <origin xyz="0.0508 0.2921 0.06985" rpy="0 0 0"/>
    </joint>

    <link name="support_back_left_block">
        <visual>
            <geometry>
                <box size="0.1016 0.0254 0.1016" />
            </geometry>
            <material name="white" />
        </visual>
        
        <collision>
            <geometry>
                <box size="0.1016 0.0254 0.1016" />
            </geometry>
        </collision>

        <xacro:inertial_box mass="0.453592" x="0.1016" y="0.0254" z="0.1016">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_box>
    </link>


        <!-- SUPPORT BLOCK BACK RIGHT LINK -->
    <joint name="support_back_right_joint" type="fixed">
        <parent link="chassis"/>
        <child link="support_back_right_block"/>
        <origin xyz="0.0508 -0.2921 0.06985" rpy="0 0 0"/>
    </joint>

    <link name="support_back_right_block">
        <visual>
            <geometry>
                <box size="0.1016 0.0254 0.1016" />
            </geometry>
            <material name="white" />
        </visual>
        
        <collision>
            <geometry>
                <box size="0.1016 0.0254 0.1016" />
            </geometry>
        </collision>

        <xacro:inertial_box mass="0.453592" x="0.1016" y="-0.0254" z="0.1016">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_box>
    </link>

    <!-- SUPPORT BLOCK FRONT LEFT LINK -->
    <joint name="support_front_left_joint" type="fixed">
        <parent link="chassis"/>
        <child link="support_front_left_block"/>
        <origin xyz="1.016 0.2921 0.06985" rpy="0 0 0"/>
    </joint>

    <link name="support_front_left_block">
        <visual>
            <geometry>
                <box size="0.1016 0.0254 0.1016" />
            </geometry>
            <material name="white" />
        </visual>
        
        <collision>
            <geometry>
                <box size="0.1016 0.0254 0.1016" />
            </geometry>
        </collision>

        <xacro:inertial_box mass="0.453592" x="0.1016" y="0.0254" z="0.1016">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_box>
    </link>

    <!-- SUPPORT BLOCK FRONT RIGHT LINK -->
    <joint name="support_front_right_joint" type="fixed">
        <parent link="chassis"/>
        <child link="support_front_right_block"/>
        <origin xyz="1.016 -0.2921 0.06985" rpy="0 0 0"/>
    </joint>

    <link name="support_front_right_block">
        <visual>
            <geometry>
                <box size="0.1016 0.0254 0.1016" />
            </geometry>
            <material name="white" />
        </visual>
        
        <collision>
            <geometry>
                <box size="0.1016 0.0254 0.1016" />
            </geometry>
        </collision>

        <xacro:inertial_box mass="0.453592" x="0.1016" y="0.0254" z="0.1016">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_box>
    </link>

    <!-- TOP BLOCK LINK -->
    <joint name="table_top_joint" type="fixed">
        <parent link="chassis"/>
        <child link="table_top_block"/>
        <origin xyz="0.5334 0 0.12065" rpy="0 0 0"/>
    </joint>

    <link name="table_top_block">
        <visual>
            <geometry>
                <box size="1.0668 0.6096 0.01905"/>
            </geometry>
            <material name="white"/>
        </visual>
        
        <collision>
            <geometry>
                <box size="1.0668 0.6096 0.01905" />
            </geometry>
        </collision>

        <xacro:inertial_box mass="7.31553774" x="1.0668" y="0.6096" z="0.1905">
            <origin xyz="0.5334 0 0.12065" rpy="0 0 0"/>
        </xacro:inertial_box>
    </link>

    <!-- TOP BACK LINK -->
    <joint name="top_back_joint" type="fixed">
        <parent link="chassis"/>
        <child link="top_back_block"/>  
        <origin xyz="0.009525 0 0.434975" rpy="0 0 0"/>
    </joint>

    <link name="top_back_block">
        <visual>
            <geometry>
                <box size="0.01905 0.6096 0.6096"/>
            </geometry>
            <material name="white"/>
        </visual>
        
        <collision>
            <geometry>
                <box size="0.01905 0.6096 0.6096" />
            </geometry>
        </collision>

        <xacro:inertial_box mass="4.032" x="0.01905" y="0.6096" z="0.6096">
            <origin xyz="0.009525 0 0.434975" rpy="0 0 0"/>
        </xacro:inertial_box>
    </link>

    <!-- TOP FRONT LINK -->
    <joint name="top_front_joint" type="fixed">
        <parent link="chassis"/>
        <child link="top_front_block"/>
        <origin xyz="1.057275 0 0.434975" rpy="0 0 0"/>
    </joint>

    <link name="top_front_block">
        <visual>

            <geometry>
                <box size="0.01905 0.6096 0.6096"/>
            </geometry>
            <material name="white"/>
        </visual>
        
        <collision>
            <geometry>
                <box size="0.01905 0.6096 0.6096" />
            </geometry>
        </collision>

        <xacro:inertial_box mass="4.032" x="0.01905" y="0.6096" z="0.6096">
            <origin xyz="1.057275 0 0.434975" rpy="0 0 0"/>
        </xacro:inertial_box>
    </link>


</robot>